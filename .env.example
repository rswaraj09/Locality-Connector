# Locality Connector - environment template.
# Copy to `.env` and fill in real values. NEVER commit the real .env file.

# --- Security (required) ---
# HMAC-SHA256 signing secret for JWTs. MUST be at least 32 characters (256 bits).
JWT_SECRET_KEY=change-me-to-a-long-random-secret-at-least-32-chars

# Comma-separated emails that are granted the ADMIN role on login.
ADMIN_EMAILS=

# Comma-separated list of allowed CORS origins.
CORS_ALLOWED_ORIGINS=http://localhost:8081

# --- Firebase (required) ---
# Path to the Firebase service account JSON. Use a classpath: resource for local dev
# or an absolute container path (see docker-compose.yml) in production.
FIREBASE_SERVICE_ACCOUNT_PATH=classpath:serviceAccountKey.json

# --- Server ---
SERVER_PORT=8081
APP_LOG_LEVEL=INFO

# --- Google Maps (optional; only needed for geocoding / nearby search) ---
GOOGLE_MAPS_API_KEY=
GOOGLE_MAPS_GEOCODING_API_KEY=
